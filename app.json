{
  "expo": {
    "name": "IronTrack",
    "slug": "irontrack",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "irontrack",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e0e0e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.irontrack.app",
      "buildNumber": "5",
      "healthKit": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSHealthShareUsageDescription": "IronTrack uses HealthKit to read your workout history and improve your experience.",
        "NSHealthUpdateUsageDescription": "IronTrack uses HealthKit to log your completed workouts to the Health app."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0e0e0e",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.irontrack.app"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "006c4ac9-75f4-4670-b486-9b40e2ed87e1"
      }
    }
  }
}